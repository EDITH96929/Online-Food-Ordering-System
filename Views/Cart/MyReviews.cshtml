@model List<FoodOrderingSystem.Models.Rating>
@{
    ViewBag.Title = "My Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var foodReviews = Model.Where(r => r.RatingType == "Food").ToList();
    var deliveryReviews = Model.Where(r => r.RatingType == "Delivery").ToList();
}

<h1 class="page-title">My Reviews</h1>

@if (Model.Count == 0)
{
    <div class="card p-5 text-center">
        <div style="font-size:3rem">⭐</div>
        <h5 class="mt-3">No reviews yet</h5>
        <p style="color:var(--muted)">
            Your food and delivery reviews will appear here after you rate an order
        </p>
        <a href="/Cart/OrderHistory" class="btn btn-green mt-2">
            <i class="bi bi-clock-history me-1"></i>View My Orders
        </a>
    </div>
}
else
{
    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <div style="font-size:1.8rem;font-weight:800;color:var(--green-dark)">
                    @Model.Count
                </div>
                <div style="font-size:0.82rem;color:var(--muted);margin-top:2px">
                    Total Reviews
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <div style="font-size:1.8rem;font-weight:800;color:#facc15">
                    @if (foodReviews.Count > 0)
                    {
                        @(foodReviews.Average(r => r.Stars).ToString("0.0"))
                    }
                    else
                    {
                        <text>—</text>
                    }
                </div>
                <div style="font-size:0.82rem;color:var(--muted);margin-top:2px">
                    Avg Food Rating
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 text-center">
                <div style="font-size:1.8rem;font-weight:800;color:#1d4ed8">
                    @if (deliveryReviews.Count > 0)
                    {
                        @(deliveryReviews.Average(r => r.Stars).ToString("0.0"))
                    }
                    else
                    {
                        <text>—</text>
                    }
                </div>
                <div style="font-size:0.82rem;color:var(--muted);margin-top:2px">
                    Avg Delivery Rating
                </div>
            </div>
        </div>
    </div>

    <!-- Food Reviews -->
    if (foodReviews.Count > 0)
    {
        <h5 style="font-weight:700;margin-bottom:1rem">
            <i class="bi bi-egg-fried me-2 text-success"></i>Food Reviews
            <span style="font-size:0.85rem;font-weight:500;color:var(--muted)">
                (@foodReviews.Count)
            </span>
        </h5>
        <div class="d-flex flex-column gap-3 mb-4">
            @foreach (var r in foodReviews)
            {
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div style="font-weight:700;font-size:0.95rem;
                                        color:var(--green-dark)">
                                @r.OrderCode
                            </div>
                            <div style="font-size:0.78rem;color:var(--muted)">
                                @r.RatedOn.ToString("dd MMM yyyy, hh:mm tt")
                            </div>
                        </div>
                        <a href="/Cart/OrderDetail?orderId=@(r.OrderId)"
                           class="btn btn-outline-green"
                           style="font-size:0.78rem;padding:0.25rem 0.7rem">
                            <i class="bi bi-receipt me-1"></i>View Order
                        </a>
                    </div>
                    <div style="color:#facc15;font-size:1rem;margin-bottom:6px">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= r.Stars)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else
                            {
                                <i class="bi bi-star" style="color:#d1d5db"></i>
                            }
                        }
                        <span style="font-size:0.82rem;color:var(--muted);margin-left:6px">
                            @r.Stars / 5
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(r.Comment))
                    {
                        <p style="font-size:0.9rem;color:var(--text);
                                  margin:0;line-height:1.6;
                                  background:var(--surface);
                                  padding:0.6rem 0.8rem;
                                  border-radius:8px;
                                  border-left:3px solid var(--green)">
                            "@r.Comment"
                        </p>
                    }
                </div>
            }
        </div>
    }

    <!-- Delivery Reviews -->
    if (deliveryReviews.Count > 0)
    {
        <h5 style="font-weight:700;margin-bottom:1rem">
            <i class="bi bi-bicycle me-2 text-success"></i>Delivery Reviews
            <span style="font-size:0.85rem;font-weight:500;color:var(--muted)">
                (@deliveryReviews.Count)
            </span>
        </h5>
        <div class="d-flex flex-column gap-3">
            @foreach (var r in deliveryReviews)
            {
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div style="font-weight:700;font-size:0.95rem;
                                        color:var(--green-dark)">
                                @r.OrderCode
                            </div>
                            <div style="font-size:0.78rem;color:var(--muted)">
                                @r.RatedOn.ToString("dd MMM yyyy, hh:mm tt")
                            </div>
                        </div>
                        <a href="/Cart/OrderDetail?orderId=@(r.OrderId)"
                           class="btn btn-outline-green"
                           style="font-size:0.78rem;padding:0.25rem 0.7rem">
                            <i class="bi bi-receipt me-1"></i>View Order
                        </a>
                    </div>
                    <div style="color:#facc15;font-size:1rem;margin-bottom:6px">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= r.Stars)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else
                            {
                                <i class="bi bi-star" style="color:#d1d5db"></i>
                            }
                        }
                        <span style="font-size:0.82rem;color:var(--muted);margin-left:6px">
                            @r.Stars / 5
                        </span>
                    </div>
                    @if (!string.IsNullOrEmpty(r.Comment))
                    {
                        <p style="font-size:0.9rem;color:var(--text);
                                  margin:0;line-height:1.6;
                                  background:var(--surface);
                                  padding:0.6rem 0.8rem;
                                  border-radius:8px;
                                  border-left:3px solid #1d4ed8">
                            "@r.Comment"
                        </p>
                    }
                </div>
            }
        </div>
    }
}