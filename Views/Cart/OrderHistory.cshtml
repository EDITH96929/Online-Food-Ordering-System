@model List<FoodOrderingSystem.Models.Order>
@{
    ViewBag.Title = "My Orders";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .order-card {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--card);
        margin-bottom: 1rem;
        transition: transform 0.2s;
    }

        .order-card:hover {
            transform: translateY(-2px);
        }

    .order-header {
        padding: 14px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-pending {
        background: #78350f;
    }

    .header-outdelivery {
        background: #1e3a5f;
    }

    .header-delivered {
        background: #14532d;
    }

    .order-body {
        padding: 18px 20px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.88rem;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .countdown-pill {
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        border-radius: 12px;
        padding: 14px;
        text-align: center;
        margin-bottom: 14px;
    }

    .otp-pill {
        background: #f0fdf4;
        border: 2px dashed #22c55e;
        border-radius: 12px;
        padding: 14px;
        text-align: center;
        margin-bottom: 14px;
    }

    .delivered-pill {
        background: #f0fdf4;
        border: 1px solid #86efac;
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .view-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: transparent;
        color: var(--green-dark);
        border: 1.5px solid var(--green);
        border-radius: 10px;
        padding: 8px 18px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

        .view-btn:hover {
            background: var(--green-light);
            color: var(--green-dark);
        }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 6px;
    }

    .amount-large {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--green-dark);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-0">My Orders</h1>
        @if (Model.Count > 0)
        {
            <p style="font-size:0.88rem;color:var(--muted);margin-top:4px">
                @Model.Count order@(Model.Count > 1 ? "s" : "") placed so far
            </p>
        }
    </div>
    <a href="/Food/Menu" class="btn btn-green">
        <i class="bi bi-plus-lg me-1"></i>Order More
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="card p-5 text-center">
        <div style="width:80px;height:80px;border-radius:50%;
                    background:#dcfce7;display:flex;align-items:center;
                    justify-content:center;font-size:2.5rem;margin:0 auto 1rem">
            📦
        </div>
        <h5 style="font-weight:700;margin-bottom:0.4rem">No orders yet</h5>
        <p style="color:var(--muted);font-size:0.9rem;margin-bottom:1.2rem">
            Your order history will appear here
        </p>
        <a href="/Food/Menu" class="btn btn-green">
            <i class="bi bi-grid me-1"></i>Browse Menu
        </a>
    </div>
}
else
{
    foreach (var order in Model)
    {
        string headerClass = order.Status == "Pending" ? "header-pending"
                           : order.Status == "OutForDelivery" ? "header-outdelivery"
                           : "header-delivered";

        string statusIcon = order.Status == "Pending" ? "bi-hourglass-split"
                          : order.Status == "OutForDelivery" ? "bi-bicycle"
                          : "bi-check-circle-fill";

        string statusLabel = order.Status == "Pending" ? "Preparing"
                           : order.Status == "OutForDelivery" ? "Out for Delivery"
                           : "Delivered";

        string dotColor = order.Status == "Pending" ? "#f59e0b"
                        : order.Status == "OutForDelivery" ? "#3b82f6"
                        : "#22c55e";

        <div class="order-card">

            <!-- Header -->
            <div class="order-header @headerClass">
                <div>
                    <div style="font-size:0.7rem;font-weight:700;
                                letter-spacing:0.8px;color:rgba(255,255,255,0.6);
                                margin-bottom:3px">
                        ORDER
                    </div>
                    <div style="font-size:1rem;font-weight:800;color:#fff">
                        @order.OrderCode
                    </div>
                    <div style="font-size:0.75rem;color:rgba(255,255,255,0.65);
                                margin-top:2px">
                        @order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                    </div>
                </div>
                <div class="text-end">
                    <div style="background:rgba(255,255,255,0.15);
                                color:#fff;font-size:0.75rem;font-weight:700;
                                padding:5px 12px;border-radius:99px;
                                margin-bottom:6px">
                        <i class="bi @statusIcon me-1"></i>@statusLabel
                    </div>
                    <div class="amount-large" style="color:#fff">
                        &#8377;@order.TotalAmount
                    </div>
                </div>
            </div>

            <!-- Body -->
            <div class="order-body">

                <!-- Delivery partner -->
                @if (!string.IsNullOrEmpty(order.DeliveryBoyName))
                {
                    <div style="display:flex;align-items:center;gap:8px;
                                margin-bottom:14px;padding:10px 12px;
                                background:var(--surface);border-radius:10px;
                                border:1px solid var(--border)">
                        <div style="width:34px;height:34px;border-radius:50%;
                                    background:#dcfce7;display:flex;
                                    align-items:center;justify-content:center;
                                    font-weight:700;color:#166534;font-size:0.85rem">
                            @order.DeliveryBoyName.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <div style="font-size:0.7rem;color:var(--muted);
                                        font-weight:600;letter-spacing:0.5px">
                                DELIVERY PARTNER
                            </div>
                            <div style="font-weight:700;font-size:0.9rem">
                                @order.DeliveryBoyName
                            </div>
                        </div>
                        <div class="ms-auto">
                            <span style="display:inline-block;width:8px;height:8px;
                                         border-radius:50%;background:@dotColor;
                                         margin-right:4px"></span>
                            <span style="font-size:0.78rem;color:var(--muted)">
                                @statusLabel
                            </span>
                        </div>
                    </div>
                }

                <!-- Countdown for OutForDelivery -->
                @if (order.Status == "OutForDelivery" &&
                     order.DeliveryStartTime.HasValue &&
                     order.DeliveryTime.HasValue)
                {
                    int secondsLeft = (int)(order.DeliveryTime.Value * 60 -
                        (DateTime.Now - order.DeliveryStartTime.Value).TotalSeconds);
                    if (secondsLeft > 0)
                    {
                        <div class="countdown-pill">
                            <div style="font-size:0.75rem;color:#1d4ed8;
                                        font-weight:700;letter-spacing:0.5px;
                                        margin-bottom:4px">
                                <i class="bi bi-bicycle me-1"></i>
                                ESTIMATED ARRIVAL
                            </div>
                            <div style="font-size:2.2rem;font-weight:800;
                                        color:#1d4ed8;font-variant-numeric:tabular-nums"
                                 id="timer-@(order.OrderId)">
                                --:--
                            </div>
                        </div>

                        <div class="otp-pill">
                            <div style="font-size:0.75rem;font-weight:700;
                                        color:var(--green-dark);letter-spacing:0.5px;
                                        margin-bottom:6px">
                                YOUR DELIVERY OTP — share only with partner
                            </div>
                            <div style="font-size:2.5rem;font-weight:800;
                                        letter-spacing:14px;color:var(--green-dark)">
                                @order.OTP
                            </div>
                        </div>

                        <script>
                            (function () {
                                var s = @(secondsLeft);
                                var el = document.getElementById('timer-@(order.OrderId)');
                                function tick() {
                                    if (s <= 0) {
                                        el.textContent = 'Arriving now!';
                                        el.style.color = '#16a34a';
                                        return;
                                    }
                                    var m = Math.floor(s / 60);
                                    var sec = s % 60;
                                    el.textContent = (m < 10 ? '0' : '') + m + ':'
                                                   + (sec < 10 ? '0' : '') + sec;
                                    s--;
                                    setTimeout(tick, 1000);
                                }
                                tick();
                            })();
                        </script>
                    }
                }

                <!-- Delivered success message -->
                @if (order.Status == "Delivered")
                {
                    <div class="delivered-pill">
                        <div style="width:36px;height:36px;border-radius:50%;
                                    background:#22c55e;display:flex;
                                    align-items:center;justify-content:center;
                                    flex-shrink:0">
                            <i class="bi bi-check-lg" style="color:#fff;font-size:1rem"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:0.9rem;color:#166534">
                                Order delivered successfully!
                            </div>
                            <div style="font-size:0.78rem;color:#166534;opacity:0.8">
                                Thank you for ordering with FoodRush
                            </div>
                        </div>
                    </div>
                }

                <!-- Pending message -->
                @if (order.Status == "Pending")
                {
                    <div style="background:#fefce8;border:1px solid #fde047;
                                border-radius:12px;padding:12px 16px;
                                margin-bottom:14px;display:flex;
                                align-items:center;gap:10px">
                        <div style="width:36px;height:36px;border-radius:50%;
                                    background:#fde047;display:flex;
                                    align-items:center;justify-content:center;
                                    flex-shrink:0;font-size:1rem">
                            ⏳
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:0.9rem;color:#854d0e">
                                Order is being prepared
                            </div>
                            <div style="font-size:0.78rem;color:#92400e">
                                Admin will assign a delivery partner soon
                            </div>
                        </div>
                    </div>
                }

                <!-- View details button -->
                <div class="d-flex justify-content-between align-items-center">
                    <div style="font-size:0.78rem;color:var(--muted)">
                        @if (order.Status == "OutForDelivery")
                        {
                            <span style="color:#1d4ed8;font-weight:600">
                                <i class="bi bi-circle-fill me-1"
                                   style="font-size:0.5rem"></i>
                                Live tracking available
                            </span>
                        }
                    </div>
                    <a href="/Cart/OrderDetail?orderId=@(order.OrderId)"
                       class="view-btn">
                        <i class="bi bi-receipt"></i>
                        View Details
                        @if (order.Status == "OutForDelivery")
                        {
                            <span style="background:#dbeafe;color:#1e40af;
                                         font-size:0.68rem;padding:2px 7px;
                                         border-radius:99px;font-weight:700">
                                LIVE
                            </span>
                        }
                    </a>
                </div>
            </div>
        </div>
    }
}