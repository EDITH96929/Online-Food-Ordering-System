@model List<FoodOrderingSystem.Models.FoodItem>
@{
    ViewBag.Title = "Menu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var categories = Model.Select(f => f.Category).Distinct().ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="page-title mb-0">Our Menu</h1>
        <p style="color:var(--muted);font-size:0.9rem">
            @Model.Count(f => !f.IsOutOfStock) items available today
        </p>
    </div>
    <input type="text" id="searchBox" class="form-control"
           placeholder="🔍  Search food..."
           style="width:220px" onkeyup="filterFood()" />
</div>

<!-- Category filter chips -->
<div class="d-flex gap-2 flex-wrap mb-4" id="categoryChips">
    <button class="cat-chip active" onclick="filterCategory('all', this)">All</button>
    @foreach (var cat in categories)
    {
        <button class="cat-chip" onclick="filterCategory('@cat', this)">@cat</button>
    }
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <div style="font-size:3rem">🍽️</div>
        <p style="color:var(--muted);margin-top:0.5rem">
            No food items available right now.
        </p>
    </div>
}
else
{
    <div class="row g-3" id="foodGrid">
        @foreach (var item in Model)
        {
            bool outOfStock = item.IsOutOfStock;

            <div class="col-md-3 col-sm-6 food-item-col"
                 data-name="@item.FoodName.ToLower()"
                 data-category="@item.Category">

                <div class="card food-card h-100 @(outOfStock ? "oos-card" : "")">

                    <!-- Image with out of stock overlay -->
                    <div style="position:relative">
                        <a href="/Food/Detail?foodId=@(item.FoodId)"
                           style="text-decoration:none;color:inherit;
                                  pointer-events:@(outOfStock ? "none" : "auto")">
                            <img src="/Content/Images/@item.ImagePath"
                                 onerror="this.src='/Content/Images/default.jpg'"
                                 alt="@item.FoodName"
                                 class="food-card-img @(outOfStock ? "oos-img" : "")" />
                        </a>

                        @if (outOfStock)
                        {
                            <!-- Dark overlay with OUT OF STOCK text like Zomato -->
                            <div style="position:absolute;top:0;left:0;right:0;bottom:0;
                                        background:rgba(0,0,0,0.55);
                                        display:flex;align-items:center;
                                        justify-content:center;
                                        border-radius:var(--radius) var(--radius) 0 0">
                                <span style="background:#1e293b;color:#fff;
                                             font-size:0.75rem;font-weight:700;
                                             padding:5px 14px;border-radius:99px;
                                             letter-spacing:1px;text-transform:uppercase">
                                    Out of Stock
                                </span>
                            </div>
                        }
                        else if (item.StockQuantity <= 5)
                        {
                            <!-- Low stock warning badge -->
                            <div style="position:absolute;top:8px;right:8px">
                                <span style="background:#f59e0b;color:#fff;
                                             font-size:0.68rem;font-weight:700;
                                             padding:3px 8px;border-radius:99px">
                                    Only @item.StockQuantity left!
                                </span>
                            </div>
                        }
                    </div>

                    <div class="food-card-body d-flex flex-column
                                @(outOfStock ? "oos-body" : "")">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <span style="font-size:0.72rem;font-weight:600;
                                         background:@(outOfStock ? "#f1f5f9" : "var(--green-light)");
                                         color:@(outOfStock ? "#94a3b8" : "var(--green-dark)");
                                         padding:2px 8px;border-radius:99px">
                                @item.Category
                            </span>
                            <div style="font-size:0.78rem;
                                        color:@(outOfStock ? "#cbd5e1" : "#facc15")">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= Math.Round(item.AverageRating))
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star" style="color:#d1d5db"></i>
                                    }
                                }
                                <span style="color:var(--muted);font-size:0.7rem">
                                    (@item.TotalRatings)
                                </span>
                            </div>
                        </div>

                        <span style="font-weight:700;font-size:1rem;
                                     color:@(outOfStock ? "#94a3b8" : "var(--text)")">
                            @item.FoodName
                        </span>

                        <p style="font-size:0.8rem;
                                  color:@(outOfStock ? "#cbd5e1" : "var(--muted)");
                                  margin:4px 0 12px;flex:1;
                                  display:-webkit-box;-webkit-line-clamp:2;
                                  -webkit-box-orient:vertical;overflow:hidden">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span style="font-size:1.15rem;font-weight:800;
                                         color:@(outOfStock ? "#94a3b8" : "var(--green-dark)")">
                                &#8377;@item.Price
                            </span>

                            @if (outOfStock)
                            {
                                <!-- Grayed out disabled button like Zomato -->
                                <button disabled
                                        style="padding:0.35rem 0.9rem;font-size:0.85rem;
                                               background:#f1f5f9;color:#94a3b8;
                                               border:1.5px solid #e2e8f0;
                                               border-radius:10px;cursor:not-allowed;
                                               font-weight:600">
                                    <i class="bi bi-x-circle me-1"></i>Unavailable
                                </button>
                            }
                            else
                            {
                                <a href="/Cart/AddToCart?foodId=@(item.FoodId)"
                                   class="btn btn-green"
                                   style="padding:0.35rem 0.9rem;font-size:0.85rem">
                                    <i class="bi bi-plus-lg me-1"></i>Add
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="noResults" class="text-center py-5" style="display:none">
        <div style="font-size:3rem">🔍</div>
        <p style="color:var(--muted);margin-top:0.5rem">
            No items found. Try a different search.
        </p>
    </div>
}

<style>
    .cat-chip {
        padding: 0.4rem 1.1rem;
        border: 1.5px solid var(--border);
        border-radius: 99px;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--muted);
        background: white;
        cursor: pointer;
        transition: all 0.15s;
    }

        .cat-chip:hover {
            border-color: var(--green);
            color: var(--green-dark);
        }

        .cat-chip.active {
            background: var(--green-light);
            border-color: var(--green);
            color: var(--green-dark);
        }

    /* Out of stock card styles */
    .oos-card {
        background: #f8fafc;
        border-color: #e2e8f0;
    }

    .oos-img {
        filter: grayscale(80%);
        opacity: 0.7;
    }

    .oos-body {
        opacity: 0.75;
    }
</style>

@section Scripts {
    <script>
        var activeCategory = 'all';

        function filterCategory(cat, btn) {
            activeCategory = cat;
            document.querySelectorAll('.cat-chip').forEach(function (c) {
                c.classList.remove('active');
            });
            btn.classList.add('active');
            applyFilters();
        }

        function filterFood() { applyFilters(); }

        function applyFilters() {
            var q = document.getElementById('searchBox').value.toLowerCase();
            var cols = document.querySelectorAll('.food-item-col');
            var visible = 0;
            cols.forEach(function (col) {
                var nameMatch = col.dataset.name.includes(q);
                var catMatch = activeCategory === 'all' ||
                    col.dataset.category === activeCategory;
                if (nameMatch && catMatch) {
                    col.style.display = '';
                    visible++;
                } else {
                    col.style.display = 'none';
                }
            });
            var noRes = document.getElementById('noResults');
            if (noRes) noRes.style.display = visible === 0 ? '' : 'none';
        }
    </script>
}