@model List<FoodOrderingSystem.Models.Order>
@{
    ViewBag.Title = "Delivery History";
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal totalEarnings = Model.Sum(o => o.TotalAmount * 0.1m);
}

<h1 class="page-title">Delivery History</h1>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:2rem;font-weight:800;color:var(--green-dark)">
                @Model.Count
            </div>
            <div style="font-size:0.85rem;color:var(--muted)">
                Total Deliveries
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:2rem;font-weight:800;color:#1e40af">
                ₹@totalEarnings.ToString("0.00")
            </div>
            <div style="font-size:0.85rem;color:var(--muted)">
                Est. Earnings (10%)
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:2rem;font-weight:800;color:#854d0e">
                @(Model.Count > 0
                    ? Model.Average(o => o.TotalAmount).ToString("0")
                    : "0")
            </div>
            <div style="font-size:0.85rem;color:var(--muted)">
                Avg Order Value (₹)
            </div>
        </div>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <div style="font-size:3.5rem">📦</div>
        <h5 class="mt-3">No completed deliveries yet</h5>
        <p class="text-muted">Your delivery history will appear here</p>
        <a href="/Delivery/MyDeliveries" class="btn btn-green mt-2">
            Go to Active Deliveries
        </a>
    </div>
}
else
{
    <div class="card">
        <div style="overflow-x:auto">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Order Code</th>
                        <th>Customer</th>
                        <th>Amount</th>
                        <th>Delivered On</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td style="font-weight:700;color:var(--green-dark)">
                                @order.OrderCode
                            </td>
                            <td>
                                <div style="font-weight:600">@order.UserName</div>
                                <div style="font-size:0.8rem;color:var(--muted)">
                                    @order.UserPhone
                                </div>
                            </td>
                            <td style="font-weight:700">₹@order.TotalAmount</td>
                            <td style="color:var(--muted);font-size:0.85rem">
                                @order.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                            </td>
                            <td>
                                <span class="status-badge status-delivered">
                                    ✅ Delivered
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}