@model List<FoodOrderingSystem.Models.Rating>
@{
    ViewBag.Title = "My Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
    double avgRating = ViewBag.AverageRating != null ? (double)ViewBag.AverageRating : 0;
}

<h1 class="page-title">My Reviews</h1>

<!-- Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:1.8rem;font-weight:800;color:var(--green-dark)">
                @Model.Count
            </div>
            <div style="font-size:0.82rem;color:var(--muted);margin-top:2px">
                Total Reviews
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:1.8rem;font-weight:800;color:#facc15">
                &#9733; @avgRating.ToString("0.0")
            </div>
            <div style="font-size:0.82rem;color:var(--muted);margin-top:2px">
                Average Rating
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 text-center">
            <div style="font-size:1.8rem;font-weight:800;color:#1d4ed8">
                @(Model.Count > 0 ? Model.Count(r => r.Stars >= 4) : 0)
            </div>
            <div style="font-size:0.82rem;color:var(--muted);margin-top:2px">
                4&#9733; and above
            </div>
        </div>
    </div>
</div>

@if (Model.Count == 0)
{
    <div class="card p-5 text-center">
        <div style="font-size:3rem">⭐</div>
        <h5 class="mt-3">No reviews yet</h5>
        <p style="color:var(--muted)">
            Customer reviews will appear here after you complete deliveries
        </p>
    </div>
}
else
{
    <!-- Star distribution -->
    <div class="card p-3 mb-4">
        <div style="font-weight:700;margin-bottom:1rem;font-size:0.95rem">
            Rating Breakdown
        </div>
        @for (int star = 5; star >= 1; star--)
        {
            int count = Model.Count(r => r.Stars == star);
            int pct = Model.Count > 0 ? (count * 100 / Model.Count) : 0;
            <div class="d-flex align-items-center gap-2 mb-2">
                <span style="font-size:0.82rem;color:var(--muted);
                             min-width:35px;text-align:right">
                    @star &#9733;
                </span>
                <div style="flex:1;background:#f1f5f9;border-radius:99px;height:8px">
                    <div style="width:@(pct)%;background:#facc15;
                                border-radius:99px;height:8px"></div>
                </div>
                <span style="font-size:0.82rem;color:var(--muted);min-width:25px">
                    @count
                </span>
            </div>
        }
    </div>

    <!-- Individual reviews -->
    <div class="d-flex flex-column gap-3">
        @foreach (var r in Model)
        {
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div class="d-flex align-items-center gap-2">
                        <div style="width:36px;height:36px;border-radius:50%;
                                    background:var(--green-light);display:flex;
                                    align-items:center;justify-content:center;
                                    font-weight:700;color:var(--green-dark)">
                            @r.UserName.Substring(0, 1).ToUpper()
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:0.92rem">@r.UserName</div>
                            <div style="font-size:0.75rem;color:var(--muted)">
                                Order @r.OrderCode
                            </div>
                        </div>
                    </div>
                    <div style="font-size:0.78rem;color:var(--muted)">
                        @r.RatedOn.ToString("dd MMM yyyy")
                    </div>
                </div>

                <div style="color:#facc15;font-size:0.95rem;margin-bottom:6px">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= r.Stars)
                        {<i class="bi bi-star-fill"></i>}
                        else
                        {<i class="bi bi-star" style="color:#d1d5db"></i>}
                    }
                    <span style="font-size:0.8rem;color:var(--muted);margin-left:6px">
                        @r.Stars / 5
                    </span>
                </div>

                @if (!string.IsNullOrEmpty(r.Comment))
                {
                    <p style="font-size:0.9rem;color:var(--text);
                              margin:0;line-height:1.6;
                              background:var(--surface);
                              padding:0.6rem 0.8rem;
                              border-radius:8px;
                              border-left:3px solid #1d4ed8">
                        "@r.Comment"
                    </p>
                }
            </div>
        }
    </div>
}