@model FoodOrderingSystem.Models.Order
@{
    ViewBag.Title = "Order Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var details = ViewBag.Details as List<FoodOrderingSystem.Models.OrderDetail>;
}

<div class="mb-3">
    <a href="/Admin/Dashboard"
       style="color:var(--green-dark);font-size:0.9rem;font-weight:600;text-decoration:none">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <div style="font-weight:800;font-size:1.1rem;color:var(--green-dark)">
                        @Model.OrderCode
                    </div>
                    <div style="font-size:0.82rem;color:var(--muted)">
                        @Model.OrderDate.ToString("dd MMM yyyy, hh:mm tt")
                    </div>
                </div>
                <span class="status-badge status-@Model.Status.ToLower()">@Model.Status</span>
            </div>

            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Price</th>
                        <th>Qty</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in details)
                    {
                        <tr>
                            <td>@d.FoodName</td>
                            <td>&#8377;@d.Price</td>
                            <td>@d.Quantity</td>
                            <td style="font-weight:700">&#8377;@d.ItemTotal</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" style="font-weight:700;text-align:right">Grand Total</td>
                        <td style="font-weight:800;color:var(--green-dark)">&#8377;@Model.TotalAmount</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="col-md-5">

        <!-- Customer Info -->
        <div class="card p-3 mb-3">
            <h6 style="font-weight:700;margin-bottom:1rem">
                <i class="bi bi-person-circle me-2"></i>Customer Info
            </h6>
            <div class="d-flex flex-column gap-2" style="font-size:0.92rem">
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted)">Name</span>
                    <span style="font-weight:600">@Model.UserName</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted)">Account Phone</span>
                    <span style="font-weight:600">@Model.UserPhone</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted)">Order OTP</span>
                    <span style="font-weight:800;font-size:1.1rem;
                                 color:var(--green-dark);letter-spacing:4px">
                        @Model.OTP
                    </span>
                </div>
            </div>
        </div>

        <!-- Delivery Address — always visible to admin -->
        @if (!string.IsNullOrEmpty(Model.DeliveryAddress) || !string.IsNullOrEmpty(Model.CustomerPhone))
        {
            <div class="card p-3 mb-3"
                 style="background:#f0fdf4;border:1.5px solid #86efac">
                <h6 style="font-weight:700;margin-bottom:1rem;color:#166534">
                    <i class="bi bi-geo-alt-fill me-2"></i>Delivery Details
                </h6>
                <div class="d-flex flex-column gap-2" style="font-size:0.92rem">
                    @if (!string.IsNullOrEmpty(Model.CustomerPhone))
                    {
                        <div class="d-flex gap-2 align-items-start">
                            <i class="bi bi-telephone-fill mt-1"
                               style="color:#166534;font-size:0.85rem"></i>
                            <span style="font-weight:600">@Model.CustomerPhone</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.DeliveryAddress))
                    {
                        <div class="d-flex gap-2 align-items-start">
                            <i class="bi bi-house-fill mt-1"
                               style="color:#166534;font-size:0.85rem"></i>
                            <span style="font-weight:600;line-height:1.5">
                                @Model.DeliveryAddress
                            </span>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Delivery Partner -->
        @if (!string.IsNullOrEmpty(Model.DeliveryBoyName))
        {
            <div class="card p-3 mb-3">
                <h6 style="font-weight:700;margin-bottom:1rem">
                    <i class="bi bi-bicycle me-2 text-success"></i>Delivery Partner
                </h6>
                <div class="d-flex flex-column gap-2" style="font-size:0.92rem">
                    <div class="d-flex justify-content-between">
                        <span style="color:var(--muted)">Name</span>
                        <span style="font-weight:600">@Model.DeliveryBoyName</span>
                    </div>
                    @if (Model.DeliveryTime.HasValue)
                    {
                        <div class="d-flex justify-content-between">
                            <span style="color:var(--muted)">Est. Time</span>
                            <span style="font-weight:600">@Model.DeliveryTime min</span>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.Status == "Pending")
        {
            <a href="/Admin/AssignDelivery?orderId=@(Model.OrderId)"
               class="btn btn-green w-100 py-2">
                <i class="bi bi-bicycle me-2"></i>Assign Delivery Partner
            </a>
        }
    </div>
</div>