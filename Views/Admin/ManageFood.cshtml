@model List<FoodOrderingSystem.Models.FoodItem>
@{
    ViewBag.Title = "Manage Food";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Manage Food</h1>
    <a href="/Admin/AddFood" class="btn btn-green">
        <i class="bi bi-plus-lg me-1"></i>Add New Item
    </a>
</div>

<div class="card">
    <div style="overflow-x:auto">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="/Content/Images/@item.ImagePath"
                                     onerror="this.src='/Content/Images/default.jpg'"
                                     style="width:42px;height:42px;object-fit:cover;border-radius:8px" />
                                <div>
                                    <div style="font-weight:700;font-size:0.92rem">@item.FoodName</div>
                                    <div style="font-size:0.78rem;color:var(--muted);
                                                max-width:180px;white-space:nowrap;
                                                overflow:hidden;text-overflow:ellipsis">
                                        @item.Description
                                    </div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <span style="font-size:0.78rem;font-weight:600;
                                         background:var(--green-light);color:var(--green-dark);
                                         padding:2px 8px;border-radius:99px">
                                @item.Category
                            </span>
                        </td>

                        <td style="font-weight:700;color:var(--green-dark)">₹@item.Price</td>

                        <td>
                            <span style="color:#facc15">★</span>
                            @item.AverageRating.ToString("0.0")
                            <span style="color:var(--muted);font-size:0.8rem">
                                (@item.TotalRatings)
                            </span>
                        </td>

                        <!-- ✅ UPDATED STATUS COLUMN WITH STOCK -->
                        <td>
                            @if (item.IsOutOfStock)
                            {
                                <span class="status-badge status-pending">Out of Stock</span>
                            }
                            else if (item.StockQuantity <= 5)
                            {
                                <span class="status-badge"
                                      style="background:#fef9c3;color:#854d0e">
                                    Low — @item.StockQuantity left
                                </span>
                            }
                            else if (item.IsAvailable)
                            {
                                <span class="status-badge status-delivered">
                                    Active (@item.StockQuantity)
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">Hidden</span>
                            }
                        </td>

                        <td>
                            <div class="d-flex gap-2">
                                <a href="/Admin/EditFood?id=@item.FoodId"
                                   class="btn btn-outline-green"
                                   style="font-size:0.8rem;padding:0.3rem 0.8rem">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>

                                <a href="/Admin/DeleteFood?id=@item.FoodId"
                                   class="btn"
                                   style="font-size:0.8rem;padding:0.3rem 0.8rem;
                                          background:#fff1f2;color:#e11d48;border:1px solid #fecdd3"
                                   onclick="return confirm('Hide this item from menu?')">
                                    <i class="bi bi-eye-slash me-1"></i>Hide
                                </a>
                            </div>
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>