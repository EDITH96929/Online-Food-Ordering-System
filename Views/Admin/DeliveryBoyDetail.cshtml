@model FoodOrderingSystem.Models.DeliveryBoy
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var ratings = ViewBag.Ratings as List<FoodOrderingSystem.Models.Rating>;
}

<div class="mb-3">
    <a href="/Admin/ManageDelivery"
       style="color:var(--green-dark);font-size:0.9rem;font-weight:600;text-decoration:none">
        <i class="bi bi-arrow-left me-1"></i>Back to Delivery Partners
    </a>
</div>

<div class="row g-4">
    <!-- Partner info -->
    <div class="col-md-4">
        <div class="card p-4 text-center mb-3">
            <div style="width:72px;height:72px;border-radius:50%;
                        background:var(--green-light);display:flex;
                        align-items:center;justify-content:center;
                        font-weight:800;color:var(--green-dark);
                        font-size:1.8rem;margin:0 auto 1rem">
                @Model.Name.Substring(0, 1).ToUpper()
            </div>
            <h5 style="font-weight:800;margin-bottom:0.3rem">@Model.Name</h5>
            <div style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem">
                @Model.Email
            </div>

            @if (Model.IsAvailable)
            {
                <span class="status-badge status-delivered">Active</span>
            }
            else
            {
                <span class="status-badge status-pending">Inactive</span>
            }
        </div>

        <div class="card p-3">
            <div class="d-flex flex-column gap-3">
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted);font-size:0.88rem">Phone</span>
                    <span style="font-weight:600;font-size:0.88rem">@Model.Phone</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted);font-size:0.88rem">Total Deliveries</span>
                    <span style="font-weight:700;color:var(--green-dark)">
                        @Model.TotalDeliveries
                    </span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted);font-size:0.88rem">Avg Rating</span>
                    <span style="font-weight:700;color:#facc15">
                        ★ @Model.AverageRating.ToString("0.0")
                    </span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="color:var(--muted);font-size:0.88rem">Joined</span>
                    <span style="font-weight:600;font-size:0.88rem">
                        @Model.JoinedOn.ToString("dd MMM yyyy")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Delivery ratings -->
    <div class="col-md-8">
        <h5 style="font-weight:800;margin-bottom:1rem">
            <i class="bi bi-star me-2 text-success"></i>
            Delivery Reviews
            <span style="font-size:0.85rem;font-weight:500;color:var(--muted)">
                (@(ratings != null ? ratings.Count : 0))
            </span>
        </h5>

        @if (ratings == null || ratings.Count == 0)
        {
            <div class="card p-4 text-center">
                <div style="font-size:2.5rem">💬</div>
                <p class="text-muted mt-2 mb-0">No delivery reviews yet.</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-3">
                @foreach (var r in ratings)
                {
                    <div class="card p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:36px;height:36px;border-radius:50%;
                                            background:var(--green-light);display:flex;
                                            align-items:center;justify-content:center;
                                            font-weight:700;color:var(--green-dark)">
                                    @r.UserName.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div style="font-weight:700;font-size:0.92rem">
                                        @r.UserName
                                    </div>
                                    <div style="font-size:0.75rem;color:var(--muted)">
                                        Order @r.OrderCode
                                    </div>
                                </div>
                            </div>
                            <div style="font-size:0.78rem;color:var(--muted)">
                                @r.RatedOn.ToString("dd MMM yyyy")
                            </div>
                        </div>
                        <div style="color:#facc15;font-size:0.9rem;margin-bottom:6px">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= r.Stars)
                                {<i class="bi bi-star-fill"></i> }
                                else
                                { <i class="bi bi-star" style="color:#d1d5db"></i>}
                            }
                            <span style="font-size:0.78rem;color:var(--muted);margin-left:4px">
                                @r.Stars / 5
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(r.Comment))
                        {
                            <p style="font-size:0.9rem;color:var(--text);margin:0;line-height:1.6">
                                "@r.Comment"
                            </p>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>