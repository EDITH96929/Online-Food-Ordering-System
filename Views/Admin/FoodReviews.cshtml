@model Dictionary<FoodOrderingSystem.Models.FoodItem, List<FoodOrderingSystem.Models.Rating>>
@{
    ViewBag.Title = "Food Reviews";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="page-title">Food Reviews</h1>

@if (Model.Count == 0)
{
    <div class="card p-5 text-center">
        <div style="font-size:3rem">⭐</div>
        <h5 class="mt-3">No food reviews yet</h5>
        <p style="color:var(--muted)">Reviews will appear here after customers rate their orders</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-4">
        @foreach (var entry in Model)
        {
            var food = entry.Key;
            var ratings = entry.Value;
            double avg = ratings.Average(r => r.Stars);

            <div class="card p-3">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <img src="/Content/Images/@food.ImagePath"
                         onerror="this.src='/Content/Images/default.jpg'"
                         style="width:56px;height:56px;object-fit:cover;border-radius:10px" />
                    <div style="flex:1">
                        <div style="font-weight:800;font-size:1rem">@food.FoodName</div>
                        <div style="font-size:0.82rem;color:var(--muted)">@food.Category</div>
                    </div>
                    <div class="text-center">
                        <div style="font-size:1.5rem;font-weight:800;color:#facc15">
                            &#9733; @avg.ToString("0.0")
                        </div>
                        <div style="font-size:0.78rem;color:var(--muted)">
                            @ratings.Count review@(ratings.Count > 1 ? "s" : "")
                        </div>
                    </div>
                </div>

                <!-- Star distribution bar -->
                <div class="mb-3">
                    @for (int star = 5; star >= 1; star--)
                    {
                        int count = ratings.Count(r => r.Stars == star);
                        int pct = ratings.Count > 0 ? (count * 100 / ratings.Count) : 0;
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span style="font-size:0.78rem;color:var(--muted);
                                         min-width:30px;text-align:right">
                                @star &#9733;
                            </span>
                            <div style="flex:1;background:#f1f5f9;
                                        border-radius:99px;height:7px">
                                <div style="width:@(pct)%;background:#facc15;
                                            border-radius:99px;height:7px;
                                            transition:width 0.5s ease"></div>
                            </div>
                            <span style="font-size:0.78rem;color:var(--muted);
                                         min-width:20px">
                                @count
                            </span>
                        </div>
                    }
                </div>

                <hr style="border-color:var(--border);margin:0.5rem 0 1rem" />

                <!-- Individual reviews -->
                <div class="d-flex flex-column gap-2">
                    @foreach (var r in ratings)
                    {
                        <div style="padding:0.75rem;background:var(--surface);
                                    border-radius:10px">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="width:30px;height:30px;border-radius:50%;
                                                background:var(--green-light);display:flex;
                                                align-items:center;justify-content:center;
                                                font-weight:700;font-size:0.8rem;
                                                color:var(--green-dark)">
                                        @r.UserName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div style="font-weight:600;font-size:0.88rem">
                                            @r.UserName
                                        </div>
                                        <div style="font-size:0.72rem;color:var(--muted)">
                                            @r.OrderCode
                                        </div>
                                    </div>
                                </div>
                                <div style="font-size:0.75rem;color:var(--muted)">
                                    @r.RatedOn.ToString("dd MMM yyyy")
                                </div>
                            </div>
                            <div style="color:#facc15;font-size:0.85rem;margin-bottom:4px">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= r.Stars)
                                    {<i class="bi bi-star-fill"></i>}
                                    else
                                    {<i class="bi bi-star" style="color:#d1d5db"></i>}
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(r.Comment))
                            {
                                <p style="font-size:0.88rem;color:var(--text);
                                          margin:0;line-height:1.5">
                                    "@r.Comment"
                                </p>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}