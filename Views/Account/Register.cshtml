@{
    ViewBag.Title = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center" style="min-height:75vh;align-items:center">
    <div class="col-md-4">
        <div class="text-center mb-4">
            <div style="font-size:2.5rem">🎉</div>
            <h1 style="font-size:1.8rem;font-weight:800">Create account</h1>
            <p class="text-muted" style="font-size:0.9rem">Join FoodRush and order great food</p>
        </div>
        <div class="card p-4">
            @if (ViewBag.Error != null)
            {
                <div class="alert d-flex align-items-center gap-2"
                     style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;color:#dc2626;font-size:0.88rem">
                    <i class="bi bi-exclamation-circle-fill"></i> @ViewBag.Error
                </div>
            }
            @using (Html.BeginForm("Register", "Account", FormMethod.Post))
            {
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.88rem;font-weight:600">Full Name</label>
                    <input type="text" name="Name" class="form-control" placeholder="Your full name" required />
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.88rem;font-weight:600">Email address</label>
                    <input type="email" name="Email" class="form-control" placeholder="you@example.com" required />
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.88rem;font-weight:600">Phone Number</label>
                    <input type="tel" name="Phone" class="form-control" placeholder="10 digit mobile number" />
                </div>
                <div class="mb-4">
                    <label class="form-label" style="font-size:0.88rem;font-weight:600">Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Create a password" required />
                </div>
                <button type="submit" class="btn btn-green w-100 py-2" style="font-size:1rem">
                    Create Account <i class="bi bi-arrow-right ms-1"></i>
                </button>
            }
            <div class="text-center mt-3" style="font-size:0.88rem;color:var(--muted)">
                Already have an account?
                <a href="/Account/Login" style="color:var(--green-dark);font-weight:600">Sign in</a>
            </div>
        </div>
    </div>
</div>